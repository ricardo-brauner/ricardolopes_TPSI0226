operacao = input("Digite a operação: ")
num1 = float(input("Digite o número 1: "))
num2 = float(input("Digite o número 2: "))

match operacao:
    case "soma":
        print(num1 + num2)
    case "subtração":
        print(num1 - num2)
    case "multiplicação":
        print(num1 * num2)
    case "divisão":
        if num2 == 0:
            print("Erro: divisão por zero!")
        else:
            print(num1 / num2)
    case _:
        print("Operação desconhecida!")